{
  "name": "structra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build":      "turbo run build",
    "test":       "turbo run test",
    "lint":       "turbo run lint",
    "dev":        "turbo run dev",
    "test:ts":    "pnpm --filter @structra/dsa-ts test",
    "test:py":    "cd packages/dsa-py && pytest",
    "test:api":   "pnpm --filter @structra/api test"
  },
  "devDependencies": {
    "turbo":      "^2.1.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.4.0"
}
