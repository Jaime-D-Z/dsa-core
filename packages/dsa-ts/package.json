{
  "name": "@structra/dsa-ts",
  "version": "1.0.0",
  "description": "Data Structures & Algorithms — TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":      "tsup src/index.ts --format esm --dts --clean",
    "test":       "vitest run --coverage",
    "test:watch": "vitest",
    "lint":       "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "tsup":                "^8.1.0",
    "typescript":          "^5.5.0",
    "vitest":              "^1.6.0"
  }
}
