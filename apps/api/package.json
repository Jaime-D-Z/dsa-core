{
  "name": "@structra/api",
  "version": "1.0.0",
  "description": "REST API powered by @structra/dsa-ts internals",
  "type": "module",
  "scripts": {
    "dev":        "tsx watch src/app.ts",
    "build":      "tsc",
    "start":      "node dist/app.js",
    "test":       "vitest run",
    "test:watch": "vitest",
    "lint":       "tsc --noEmit"
  },
  "dependencies": {
    "@structra/dsa-ts":   "workspace:*",
    "express":            "^4.19.2",
    "zod":                "^3.23.8",
    "jsonwebtoken":       "^9.0.2",
    "swagger-jsdoc":      "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express":            "^4.17.21",
    "@types/jsonwebtoken":       "^9.0.6",
    "@types/swagger-jsdoc":      "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx":                       "^4.15.0",
    "typescript":                "^5.5.0",
    "vitest":                    "^1.6.0"
  }
}
